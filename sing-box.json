        "type": "remote",
        "url": "https://raw.githubusercontent.com/yahngming/rules/master/emby.json",
        "download_detour": "direct"
      },
      {
        "tag": "force",
        "type": "remote",
        "url": "https://raw.githubusercontent.com/yahngming/rules/master/force.json",
        "download_detour": "direct"
      },
      {
        "tag": "game",
        "type": "remote",
        "url": "https://raw.githubusercontent.com/yahngming/rules/master/game.json",
        "download_detour": "direct"
      },
      {
        "tag": "github",
        "type": "remote",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-github.srs",
        "download_detour": "direct"
      },
      {
